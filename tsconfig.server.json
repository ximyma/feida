{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist/server",
    "rootDir": "server",
    "declaration": true,
    "resolveJsonModule": true
  },
  "include": ["server"],
  "exclude": ["node_modules", "dist"]
}
